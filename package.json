  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.3.0",
    "@google/clasp": "^3.2.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/validator": "^13.15.10",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.18",
